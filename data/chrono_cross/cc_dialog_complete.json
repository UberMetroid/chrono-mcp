  },
  {
    "offset": "0x2602dd",
    "text": "An Ancient Fort -"
  },
  {
    "offset": "0x2602ef",
    "text": "Chasing phantoms in one's dreams..."
  },
  {
    "offset": "0x260315",
    "text": "Arni Village -"
  },
  {
    "offset": "0x260324",
    "text": "Where the tides start to turn..."
  },
  {
    "offset": "0x260356",
    "text": "A calling from beyond time..."
  },
  {
    "offset": "0x260385",
    "text": "Nothing has changed but everything!"
  },
  {
    "offset": "0x2603b7",
    "text": "A reminder of one's former self..."
  },
  {
    "offset": "0x2603dc",
    "text": "Heading North -"
  },
  {
    "offset": "0x2603ec",
    "text": "In search of some answers..."
  },
  {
    "offset": "0x26040b",
    "text": "The Port Town of Termina -"
  },
  {
    "offset": "0x260426",
    "text": "The pride of the Acacia Dragoons..."
  },
  {
    "offset": "0x26045a",
    "text": "Where lies the key to the past..."
  },
  {
    "offset": "0x260488",
    "text": "Where ripples become waves..."
  },
  {
    "offset": "0x2604bc",
    "text": "Meeting with the 'other' swordsman..."
  },
  {
    "offset": "0x2604e3",
    "text": "HFrom Pirate Ship to Ghost Ship -"
  },
  {
    "offset": "0x260505",
    "text": "A mariner's worst nightmare..."
  },
  {
    "offset": "0x260525",
    "text": "POn to Water Dragon Isle -"
  },
  {
    "offset": "0x260540",
    "text": "In search of the dragon blue..."
  },
  {
    "offset": "0x260572",
    "text": "Ancient dragons' dream in ruins..."
  },
  {
    "offset": "0x2605a9",
    "text": "Where lost souls wander..."
  },
  {
    "offset": "0x2605c5",
    "text": "lBack from the Darkness -"
  },
  {
    "offset": "0x2605df",
    "text": "And on with a new journey..."
  },
  {
    "offset": "0x260610",
    "text": "Isolation of people from the world..."
  },
  {
    "offset": "0x260643",
    "text": "Knight or day...?"
  },
  {
    "offset": "0x260661",
    "text": "The village of the demi-humans..."
  },
  {
    "offset": "0x260685",
    "text": "The Masamune -"
  },
  {
    "offset": "0x260694",
    "text": "The blood-stained sword of evil..."
  },
  {
    "offset": "0x2606c8",
    "text": "A place forsaken by the gods..."
  },
  {
    "offset": "0x2606fe",
    "text": "And the planet began to shake..."
  },
  {
    "offset": "0x260720",
    "text": "\u5eddack to Viper Manor -"
  },
  {
    "offset": "0x260737",
    "text": "A captive audience awaits..."
  },
  {
    "offset": "0x26076b",
    "text": "Pursuers with heavy-hearts..."
  },
  {
    "offset": "0x26078a",
    "text": "\uff6cTo the Sea of Eden -"
  },
  {
    "offset": "0x2607a0",
    "text": "Through the hidden holes in time..."
  },
  {
    "offset": "0x2607c5",
    "text": "\uff78The Arbiter of Time -"
  },
  {
    "offset": "0x2607dc",
    "text": "On whom the three Fates smile..."
  },
  {
    "offset": "0x2607fe",
    "text": "\uff83Terra Tower -"
  },
  {
    "offset": "0x26080d",
    "text": "Caught in an echo of time..."
  },
  {
    "offset": "0x26082b",
    "text": "\uff8aChrono Cross -"
  },
  {
    "offset": "0x26083b",
    "text": "The point where destinies meet..."
  },
  {
    "offset": "0x26085e",
    "text": "\uff91For all the Dreamers -"
  },
  {
    "offset": "0x260876",
    "text": "Our planet's dream is not over yet..."
  },
